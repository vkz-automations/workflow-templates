    {
      "parameters": {
        "jsCode": "// Parse the Telegram message \u2014 user sends the content topic\nconst msg = $input.first().json.message;\nconst topic = (msg.text || '').trim().substring(0, 200);\nconst chatId = msg.chat.id;\n\nif (!topic) {\n  throw new Error('No topic received \u2014 send me a topic to write about');\n}\n\nreturn [{\n  json: {\n    topic,\n    chatId,\n    iterationCount: 0,\n    criticFeedback: '',\n    startTime: new Date().toISOString()\n  }\n}];"
      },
      "id": "parse-input",
      "name": "Parse Input",
      "type": "n8n-nodes-base.code",
      "position": [
        -1776,
        640
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "chatId": "={{ $json.chatId }}",
        "text": "=\u270d\ufe0f Content team activated!\n\nTopic: {{ $json.topic }}\n\nResearching \u2192 Writing \u2192 Reviewing. I'll send you the draft when it's ready for your approval.",
        "additionalFields": {
          "appendAttribution": false
        }
      },
      "id": "send-start",
      "name": "Send Start Notification",
      "type": "n8n-nodes-base.telegram",
      "position": [
        -1488,
        496
      ],
      "typeVersion": 1.2,
      "webhookId": "content-start-tg-v1",
      "credentials": {
        "telegramApi": {
          "id": "pALi1KMjfLC968Ex",
          "name": "Telegram account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Prepare data for the Writer Agent\n// Handles BOTH first pass (from Research Agent) AND loop rewrites (from Inject Feedback)\n\nlet topic, chatId, iterationCount, criticFeedback, keyPoints, context, angle;\n\nif ($json.output) {\n  // --- FIRST PASS: input is Research Agent plain text output ---\n  const research = $json.output;\n  const parseData = $('Parse Input').first().json;\n\n  keyPoints = [research];\n  context = research;\n  angle = '';\n  topic = parseData.topic;\n  chatId = parseData.chatId;\n  iterationCount = parseData.iterationCount;\n  criticFeedback = parseData.criticFeedback || '';\n} else {\n  // --- LOOP REWRITE: input is Inject Feedback output ---\n  keyPoints = $json.keyPoints || [];\n  context = $json.context || '';\n  angle = $json.angle || '';\n  topic = $json.topic;\n  chatId = $json.chatId;\n  iterationCount = $json.iterationCount;\n  criticFeedback = $json.criticFeedback || '';\n}\n\nconst keyPointsText = Array.isArray(keyPoints)\n  ? keyPoints.map((p, i) => `${i + 1}. ${p}`).join('\\n')\n  : keyPoints;\n\nconst feedbackSection = criticFeedback\n  ? `\\n\\nCRITIC FEEDBACK \u2014 address these points in your rewrite:\\n${criticFeedback}`\n  : '';\n\nconst writerPrompt = `Topic: ${topic}\\n\\nAngle to use: ${angle}\\n\\nContext: ${context}\\n\\nKey facts to weave in:\\n${keyPointsText}${feedbackSection}`;\n\nreturn [{\n  json: {\n    topic,\n    chatId,\n    iterationCount,\n    criticFeedback,\n    keyPoints,\n    context,\n    angle,\n    writerPrompt\n  }\n}];"
      },
      "id": "prep-writer-prompt",
      "name": "Prepare Writer Prompt",
      "type": "n8n-nodes-base.code",
      "position": [
        -1200,
        800
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "jsCode": "// Extract Writer Agent output and carry all data forward for the Critic Agent\n\nconst draft = $json.output;\nconst prevData = $('Prepare Writer Prompt').item.json;\n\nif (!draft) {\n  throw new Error('Writer Agent returned no draft');\n}\n\nreturn [{\n  json: {\n    topic: prevData.topic,\n    chatId: prevData.chatId,\n    iterationCount: prevData.iterationCount,\n    keyPoints: prevData.keyPoints,\n    context: prevData.context,\n    angle: prevData.angle,\n    criticFeedback: prevData.criticFeedback,\n    draft,\n    wordCount: draft.split(' ').length\n  }\n}];"
      },
      "id": "prep-critic-prompt",
      "name": "Prepare Critic Prompt",
      "type": "n8n-nodes-base.code",
      "position": [
        -624,
        544
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "jsCode": "// Extract Critic Agent output\n\nconst criticOutput = $json.output || '';\nconst prevData = $('Prepare Critic Prompt').item.json;\n\n// Parse score from text output\nconst scoreMatch = criticOutput.match(/\\b([0-9]|10)\\s*\\/\\s*10|\\bscore[:\\s]+([0-9]|10)\\b/i);\nconst score = scoreMatch ? parseInt(scoreMatch[1] || scoreMatch[2]) : 7;\nconst passed = score >= 7;\nconst feedback = criticOutput;\n\nreturn [{\n  json: {\n    topic: prevData.topic,\n    chatId: prevData.chatId,\n    iterationCount: prevData.iterationCount,\n    keyPoints: prevData.keyPoints,\n    context: prevData.context,\n    angle: prevData.angle,\n    draft: prevData.draft,\n    wordCount: prevData.wordCount,\n    score,\n    passed,\n    feedback\n  }\n}];"
      },
      "id": "extract-critic",
      "name": "Extract Critic Output",
      "type": "n8n-nodes-base.code",
      "position": [
        -48,
        544
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "version": 2
          },
          "conditions": [
            {
              "id": "score-pass",
              "leftValue": "={{ $json.score }}",
              "rightValue": 7,
              "operator": {
                "type": "number",
                "operation": "gte"
              }
            },
            {
              "id": "max-rewrites",
              "leftValue": "={{ $json.iterationCount }}",
              "rightValue": 2,
              "operator": {
                "type": "number",
                "operation": "gte"
              }
            }
          ],
          "combinator": "or"
        },
        "options": {}
      },
      "id": "score-gate",
      "name": "Score Gate",
      "type": "n8n-nodes-base.if",
      "position": [
        176,
        544
      ],
      "typeVersion": 2.2
    },
    {
      "parameters": {
        "jsCode": "// Draft didn't pass auto-review \u2014 inject critic feedback and loop back to writer\n\nconst improvementText = ($json.feedback || '').trim();\n\nreturn [{\n  json: {\n    topic: $json.topic,\n    chatId: $json.chatId,\n    iterationCount: $json.iterationCount + 1,\n    keyPoints: $json.keyPoints,\n    context: $json.context,\n    angle: $json.angle,\n    criticFeedback: improvementText,\n    draft: $json.draft\n  }\n}];"
      },
      "id": "inject-feedback",
      "name": "Inject Feedback",
      "type": "n8n-nodes-base.code",
      "position": [
        400,
        592
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "jsCode": "// Build approval message data\n\nconst resumeUrl = $execution.resumeUrl;\nconst approveUrl = resumeUrl + '?action=approve';\nconst rejectUrl = resumeUrl + '?action=reject';\n\nconst iterationNote = $json.iterationCount > 0\n  ? `\ud83d\udcdd Rewrite #${$json.iterationCount} \u2014 Critic score: ${$json.score}/10`\n  : `\ud83c\udfaf Critic score: ${$json.score}/10`;\n\nconst approvalMessage = `${iterationNote}\\nWords: ${$json.wordCount}\\n\\nTap below to approve or reject.`;\n\nreturn [{\n  json: {\n    approvalMessage,\n    approveUrl,\n    rejectUrl,\n    topic: $json.topic,\n    chatId: $json.chatId,\n    draft: $json.draft,\n    score: $json.score,\n    feedback: $json.feedback,\n    wordCount: $json.wordCount,\n    iterationCount: $json.iterationCount,\n    keyPoints: $json.keyPoints,\n    context: $json.context,\n    angle: $json.angle\n  }\n}];"
      },
